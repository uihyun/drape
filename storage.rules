rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Storage rules quirk: `allow write` covers create + update + delete.
    // On DELETE, request.resource is NULL (no incoming bytes). If a rule
    // requires request.resource.size / contentType for write, deletes
    // 403. Every owner-writable path below uses the same pattern:
    //   request.resource == null  OR  (size && contentType valid)
    // so deletes pass while uploads still get validated.

    // ── items/{uid}/{itemId}/(original|cropped).<ext> ──────────────────
    // Closet item images. Public read so public boards / shared outfits
    // can render the composition for non-owners (and signed-out
    // visitors). Owner-only write. Clothing photos aren't sensitive
    // identity data — that's why this differs from /identity/ and
    // /generations/, which stay private.
    match /items/{userId}/{itemId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 12 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── identity/{uid}/{n}.jpg ─────────────────────────────────────────
    // User's identity reference photos for virtual try-on. Private.
    match /identity/{userId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 12 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── tryon-input/{uid}/{tempId}.jpg ─────────────────────────────────
    // One-shot custom photo a user uploads for a single try-on (instead of
    // their permanent identity refs). Owner-only read/write. Cleaned up
    // by a TTL job later — for now the user can delete via /admin if they
    // really care. 12 MB cap so we don't accept multi-MB raws.
    match /tryon-input/{userId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 12 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── generations/{uid}/{generationId}/{idx}.png ─────────────────────
    // Virtual try-on results. Server writes the variants via the
    // virtualTryOn callable; client can delete its own results.
    match /generations/{userId}/{generationId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource == null; // delete only — uploads are server-only
    }

    // ── analyzed/{uid}/<id>.jpg ───────────────────────────────────────
    // Source photo of an AnalyzePhoto session saved into outfits with
    // kind='analyzed'. Outfit cover URL points here. Public read so the
    // card thumbnail loads on the shared profile view; owner-only write.
    match /analyzed/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 12 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── ootds/{uid}/<YYYY-MM-DD>.jpg ───────────────────────────────────
    // Per-day OOTD selfies. Public read so the photo loads on the
    // Discover feed (OOTDs published via isPublic=true are shared there);
    // owner-only write. Combining read+write into one rule with a
    // request.resource check broke download-URL reads — split for
    // clarity (matches every other path's pattern).
    match /ootds/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 8 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── outfit covers (optional) ───────────────────────────────────────
    // If an outfit picks a try-on result as cover, the URL points back to
    // generations/... above (private-by-default). If the user uploads a
    // separate cover/collage we land it here. Outfit is public when
    // isListed=true, so the cover must be public-readable.
    match /outfits/{userId}/{outfitId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 12 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── users/{uid}/profile/<filename> ─────────────────────────────────
    // Profile avatar. Public read.
    match /users/{userId}/profile/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }

    // ── dm/{uid}/{threadId}/<id>.jpg ───────────────────────────────────
    // DM photo messages. Any signed-in user may read (download URLs carry
    // an unguessable token, so they're effectively private to whoever has
    // the link — Storage rules can't reach Firestore to verify thread
    // membership). Only the sender writes, under their own prefix; the 8MB
    // cap backs the client-side compression.
    match /dm/{userId}/{threadId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || (
          request.resource.size < 8 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        ));
    }
  }
}
