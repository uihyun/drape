{
  "name": "drape",
  "version": "1.1.1",
  "description": "Digital closet + virtual try-on + OOTD calendar + lookbook SNS",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "ship": "./scripts/ship.sh",
    "ship:full": "./scripts/ship.sh --functions --rules",
    "ship:web": "./scripts/ship.sh --skip-ios",
    "serve": "firebase serve",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/firestore-rules.test.js\"",
    "test:unit": "vitest run tests/",
    "check": "node scripts/check.mjs",
    "check:fast": "node scripts/check.mjs --fast",
    "cap:sync": "npm run build && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor-firebase/authentication": "^7.5.0",
    "@capacitor-firebase/messaging": "^7.5.0",
    "@capacitor/android": "^7.6.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.6.2",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.6.2",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/share": "^7.0.4",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "firebase": "^11.10.0",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.2",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "patch-package": "^8.0.1",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "closet",
    "virtual-try-on",
    "ootd",
    "lookbook",
    "fashion",
    "ai",
    "gemini",
    "firebase"
  ],
  "author": "",
  "license": "ISC"
}
