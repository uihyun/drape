rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users/{uid} ────────────────────────────────────────────────────
    // Self-readable. Profile-shaped fields self-writable; counter fields
    // (followerCount, followingCount) are server-only. identityRefs is
    // self-writable so the identity-service can manage reference photos.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(
            ['followerCount', 'followingCount']
           );

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['followerCount', 'followingCount']);

      allow delete: if false;
    }

    // ── Reports ────────────────────────────────────────────────────────
    // Doc ID convention: `${uid}_${targetType}_${targetId}` (one report per
    // user per target). Server-only read.
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['outfit', 'item', 'ootd', 'board', 'profile']
        && request.resource.data.targetId is string
        && request.resource.data.reason is string
        && request.resource.data.reason in ['spam', 'nsfw', 'copyright', 'other']
        && reportId == request.auth.uid + '_' + request.resource.data.targetType + '_' + request.resource.data.targetId;
      allow update, delete: if false;
    }

    // ── Items (the closet) ─────────────────────────────────────────────
    match /items/{itemId} {
      // Single-doc reads are public so visitors viewing someone's public
      // board can fetch each sticker's item doc (for its image URL).
      // List queries still require owner scope — clients query with
      // where('userId', '==', uid); attempts to enumerate the whole
      // collection fail because per-doc evaluation rejects items owned
      // by other users.
      allow get: if true;
      // Owner-scoped list (closet queries) OR public listings query
      // (marketplace surface filters items where forSale == true).
      allow list: if (request.auth != null
          && resource.data.userId == request.auth.uid)
        || resource.data.forSale == true;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status is string;

      // Owner edits: tag corrections, rename, favorite, archive toggle. The
      // status / croppedUrl / tags fields land via the processItem function;
      // the reprocess flow flips status back to 'processing' from the client.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'notes', 'tags', 'isArchived', 'isFavorite',
                      'status', 'updatedAt', 'originalUrl', 'originalPath',
                      // Wear history maintained when an OOTD is recorded —
                      // see ItemService.recordWear / OotdService.upsertOotd.
                      'wearLog', 'lastWornAt', 'wornCount',
                      // Marketplace listing flags (set when owner lists the
                      // item for sale). Schema enforced client-side; rules
                      // just allow the keys through.
                      'forSale', 'priceOriginal', 'priceAsking',
                      'conditionGrade', 'currency', 'listedAt']);

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Outfits ───────────────────────────────────────────────────────
    // UNIFIED outfits: a "look". Public if isPublic (or legacy isListed)=true.
    // A dated outfit (date set) is an "OOTD" — surfaced on calendar + feed.
    match /outfits/{outfitId} {
      allow read: if resource.data.isPublic == true
        || resource.data.isListed == true
        || (request.auth != null && resource.data.userId == request.auth.uid);

      // itemIds optional (photo-OOTDs and analyzed captures can have none).
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if (
        request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'notes', 'note', 'itemIds', 'tags', 'coverUrl', 'coverPath',
                      'isPublic', 'isListed', 'listedAt', 'updatedAt',
                      'selfLiked', 'selfLikedAt',
                      'likeCount', 'likedBy',
                      'kind', 'source', 'detectedItems', 'sourcePhotoUrl', 'sourcePhotoPath',
                      'mood', 'stylingTips', 'palette', 'composition',
                      // OOTD fields now on the unified doc:
                      'date', 'outfitId', 'linkedType', 'photoUrl', 'photoPath',
                      'photoCutUrl', 'photoCutPath', 'pieces', 'isCalendarRep', 'analyzedAt', 'style'])
      ) || (
        // Like / unlike — any signed-in user, only the likedBy + count keys.
        request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount', 'likedBy'])
        && (
          (
            request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1
          ) || (
            !request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1
          )
        )
      );

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['text', 'updatedAt']);
        allow delete: if request.auth != null
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/outfits/$(outfitId)).data.userId == request.auth.uid
          );
      }
    }

    // ── OOTDs (daily calendar) ─────────────────────────────────────────
    // Doc id is `${uid}_${YYYY-MM-DD}`. Always owner-only.
    match /ootds/{ootdId} {
      // Owner always reads; everyone reads when the OOTD is published
      // (isPublic == true) — this is what powers the Discovery feed.
      allow read: if (resource.data.isPublic == true)
        || (request.auth != null && resource.data.userId == request.auth.uid);
      // Doc id is no longer constrained to ${uid}_${date} — multi-OOTD
      // per day requires auto-id docs. Existing ${uid}_${date} docs
      // still validate (userId + date checks unchanged).
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.date is string;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Owner can update anything on their own OOTD.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Like / unlike — any signed-in user on a published OOTD, only
      // the likedBy + likeCount keys, must include themselves +1 / -1.
      allow update: if request.auth != null
        && resource.data.isPublic == true
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount', 'likedBy'])
        && (
          (request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1)
          ||
          (!request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1)
        );

      // Comments — same shape as outfits. Public-readable; signed-in users
      // can post; comment owner OR OOTD owner can delete.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['text', 'updatedAt']);
        allow delete: if request.auth != null
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/ootds/$(ootdId)).data.userId == request.auth.uid
          );
      }
    }

    // ── Generations (virtual try-on + feedback loop) ───────────────────
    match /generations/{generationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if false; // only the virtualTryOn Cloud Function
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['liked', 'likedAt']);
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        // Generation comments are private by design — the generation itself
        // is owner-only, so any path that reaches this subcollection belongs
        // to the owner's session. We avoid get() to keep onSnapshot working.
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['text', 'updatedAt']);
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }

    // ── Boards (sticker-board: clothing items arranged on a canvas) ────
    // Each board doc holds an array of placed stickers (itemId + x/y/
    // scale/rotation/zIndex). Public boards readable by anyone (auth or
    // not — Discovery feed); private boards owner-only.
    match /boards/{boardId} {
      allow read: if resource.data.isPublic == true
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.stickers is list;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'stickers', 'coverUrl', 'updatedAt', 'isPublic',
                      'background', 'ratio', 'selfLiked', 'selfLikedAt',
                      'likeCount', 'likedBy']);
      // Like / unlike — any signed-in user on a public board, only the
      // likedBy + likeCount keys, must include themselves +1 / -1.
      allow update: if request.auth != null
        && resource.data.isPublic == true
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount', 'likedBy'])
        && (
          (request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1)
          ||
          (!request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1)
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Comments — same shape as outfits / ootds.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['text', 'updatedAt']);
        allow delete: if request.auth != null
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/boards/$(boardId)).data.userId == request.auth.uid
          );
      }
    }

    // ── Threads + messages (marketplace DM) ────────────────────────────
    // Thread id convention: `${minUid}_${maxUid}_${itemId}` so the same
    // buyer/seller pair opening the same listing always lands in one
    // canonical thread (idempotent set). Threads + messages are private
    // to their two participants.
    match /threads/{threadId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.itemId is string;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        // participants list is immutable
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.itemId == resource.data.itemId;
      allow delete: if false;

      match /messages/{messageId} {
        // Participant-only read; create requires fromUid == auth.uid and
        // a non-empty text under the 1k cap. No update/delete in v1.
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }

    // ── FCM device tokens (push) ───────────────────────────────────────
    // Self-write only. The sendNewMessagePush function reads these via
    // admin SDK (which bypasses rules), so we don't allow client reads.
    match /users/{userId}/fcmTokens/{token} {
      allow read: if false;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── Bookmarks (saved outfits) ──────────────────────────────────────
    match /users/{userId}/bookmarks/{outfitId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── Lookbooks (collections of outfits) ─────────────────────────────
    match /collections/{collectionId} {
      allow read: if resource.data.isPublic == true
        || (request.auth != null && resource.data.ownerId == request.auth.uid);

      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80;

      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'description', 'isPublic']);

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      match /items/{outfitId} {
        allow read: if get(/databases/$(database)/documents/collections/$(collectionId)).data.isPublic == true
          || (request.auth != null
              && get(/databases/$(database)/documents/collections/$(collectionId)).data.ownerId == request.auth.uid);
        allow create, delete: if request.auth != null
          && get(/databases/$(database)/documents/collections/$(collectionId)).data.ownerId == request.auth.uid;
        allow update: if false;
      }
    }

    // ── Public profile + handles ───────────────────────────────────────
    match /profiles/{userId} {
      allow read: if true;
      allow write: if false;
    }
    match /handles/{handle} {
      allow read: if true;
      allow write: if false;
    }

    // ── Follows + blocks ───────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && followId == request.auth.uid + '_' + request.resource.data.followingId
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId is string
        && request.resource.data.followingId != request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /blocks/{blockId} {
      allow read: if request.auth != null
        && resource.data.blockerId == request.auth.uid;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && blockId == request.auth.uid + '_' + request.resource.data.blockedId
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && request.resource.data.blockedId != request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.blockerId == request.auth.uid;
      allow update: if false;
    }

    // ── Error logs ─────────────────────────────────────────────────────
    match /errorLogs/{logId} {
      allow create: if true;
      allow read: if request.auth != null
        && request.auth.token.email in ['uihyunkei@gmail.com'];
    }

    // ── Rate limits + admin — backend only ─────────────────────────────
    match /rateLimits/{identifier} {
      allow read, write: if false;
    }
    match /admin/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email in ['uihyunkei@gmail.com'];
    }
  }
}
